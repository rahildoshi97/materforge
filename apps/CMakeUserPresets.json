{
    "version": 6,
    "configurePresets": [
        {
            "name": "lumi-cpu",
            "displayName": "LUMI CPU Build",
            "description": "Production CPU build on LUMI",
            "inherits": "local-release-cpu",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "TARGET_PLATFORM": "CPU",
                "CMAKE_C_COMPILER": "cc",
                "CMAKE_CXX_COMPILER": "CC",
                "Python_ROOT_DIR": "/pfs/lustrep1/projappl/project_465001284/venvs/materforge",
                "Python_EXECUTABLE": "/pfs/lustrep1/projappl/project_465001284/venvs/materforge/bin/python"
            },
            "binaryDir": "${sourceDir}/build/lumi-cpu"
        },
        {
            "name": "lumi-gpu",
            "displayName": "LUMI GPU Build (HIP gfx90a)",
            "description": "Production GPU build on LUMI-G with ROCm HIP",
            "inherits": "local-release-gpu",
            "environment": {
                "ROCM_PATH": "/opt/rocm-6.0.3",
                "HIP_PATH": "/opt/rocm-6.0.3",
                "CMAKE_PREFIX_PATH": "/opt/rocm-6.0.3:/opt/rocm-6.0.3/lib/cmake",
                "HIP_PLATFORM": "amd"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "TARGET_PLATFORM": "GPU-HIP",
                "CMAKE_C_COMPILER": "hipcc",
                "CMAKE_CXX_COMPILER": "hipcc",
                "CMAKE_CXX_FLAGS": "--offload-arch=gfx90a",
                "CMAKE_HIP_ARCHITECTURES": "gfx90a",
                "Python_ROOT_DIR": "/project/project_465001284/venvs/materforge",
                "Python_EXECUTABLE": "/project/project_465001284/venvs/materforge/bin/python"
            },
            "binaryDir": "${sourceDir}/build/lumi-gpu"
        },
        {
            "name": "lumi-debug-gpu",
            "displayName": "LUMI GPU Debug Build (HIP gfx90a)",
            "description": "Debug GPU build on LUMI-G with ROCm HIP",
            "inherits": "local-debug-gpu",
            "environment": {
                "ROCM_PATH": "/opt/rocm-6.0.3",
                "HIP_PATH": "/opt/rocm-6.0.3",
                "CMAKE_PREFIX_PATH": "/opt/rocm-6.0.3:/opt/rocm-6.0.3/lib/cmake",
                "HIP_PLATFORM": "amd"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "TARGET_PLATFORM": "GPU-HIP",
                "CMAKE_C_COMPILER": "hipcc",
                "CMAKE_CXX_COMPILER": "hipcc",
                "CMAKE_CXX_FLAGS": "--offload-arch=gfx90a",
                "CMAKE_HIP_ARCHITECTURES": "gfx90a",
                "Python_ROOT_DIR": "/project/project_465001284/venvs/materforge",
                "Python_EXECUTABLE": "/project/project_465001284/venvs/materforge/bin/python"
            },
            "binaryDir": "${sourceDir}/build/lumi-debug-gpu"
        }
    ],
    "buildPresets": [
        {
            "name": "lumi-cpu-build",
            "configurePreset": "lumi-cpu",
            "jobs": 16
        },
        {
            "name": "lumi-gpu-build",
            "configurePreset": "lumi-gpu",
            "jobs": 16
        },
        {
            "name": "lumi-debug-gpu-build",
            "configurePreset": "lumi-debug-gpu",
            "jobs": 16
        }
    ]
}
