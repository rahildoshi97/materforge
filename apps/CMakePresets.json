{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "local-debug-cpu",
            "displayName": "Local Debug CPU",
            "description": "Debug build with CPU-only support",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/local-debug-cpu",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "TARGET_PLATFORM": "CPU",
                "CMAKE_C_COMPILER": "/usr/bin/gcc",
                "CMAKE_CXX_COMPILER": "/usr/bin/g++",
                "Python_ROOT_DIR": "${sourceDir}/../venvs/materforge",
                "Python_EXECUTABLE": "${sourceDir}/../venvs/materforge/bin/python"
            }
        },
        {
            "name": "local-release-cpu",
            "displayName": "Local Release CPU",
            "description": "Release build with CPU-only support",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/local-release-cpu",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "TARGET_PLATFORM": "CPU",
                "CMAKE_C_COMPILER": "/usr/bin/gcc",
                "CMAKE_CXX_COMPILER": "/usr/bin/g++",
                "Python_ROOT_DIR": "${sourceDir}/../venvs/materforge",
                "Python_EXECUTABLE": "${sourceDir}/../venvs/materforge/bin/python"
            }
        },
        {
            "name": "local-debug-gpu",
            "displayName": "Local Debug GPU (CUDA)",
            "description": "Debug build with CUDA GPU support",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/local-debug-gpu",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "TARGET_PLATFORM": "GPU-CUDA",
                "CMAKE_C_COMPILER": "/usr/bin/gcc",
                "CMAKE_CXX_COMPILER": "/usr/bin/g++",
                "Python_ROOT_DIR": "${sourceDir}/../venvs/materforge",
                "Python_EXECUTABLE": "${sourceDir}/../venvs/materforge/bin/python"
            }
        },
        {
            "name": "local-release-gpu",
            "displayName": "Local Release GPU (CUDA)",
            "description": "Release build with CUDA GPU support",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/local-release-gpu",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "TARGET_PLATFORM": "GPU-CUDA",
                "WALBERLA_BUILD_WITH_GPU_SUPPORT": "ON",
                "CMAKE_C_COMPILER": "/usr/bin/gcc",
                "CMAKE_CXX_COMPILER": "/usr/bin/g++",
                "Python_ROOT_DIR": "${sourceDir}/../venvs/materforge",
                "Python_EXECUTABLE": "${sourceDir}/../venvs/materforge/bin/python"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "local-debug-cpu-build",
            "configurePreset": "local-debug-cpu",
            "jobs": 8
        },
        {
            "name": "local-release-cpu-build",
            "configurePreset": "local-release-cpu",
            "jobs": 8
        },
        {
            "name": "local-debug-gpu-build",
            "configurePreset": "local-debug-gpu",
            "jobs": 8
        },
        {
            "name": "local-release-gpu-build",
            "configurePreset": "local-release-gpu",
            "jobs": 8
        }
    ]
}
