include LICENSE
include README.md
include AUTHORS.txt
include CHANGELOG.md
include CITATION.cff
include pyproject.toml

# Source code and package data
graft src

# Documentation source only - not the compiled build output
graft docs
prune docs/_build

# Exclusions - not part of the library distribution
prune apps
prune examples
prune tests
prune scripts

# Exclude generated plots anywhere in the tree
global-exclude *.png
prune */materforge_plots

# Build artefacts
prune build
prune dist
prune src/*.egg-info

# Bytecode and caches
global-exclude *.py[co]
global-exclude __pycache__
global-exclude .pytest_cache

# OS and editor noise
global-exclude .DS_Store
global-exclude .git*
global-exclude .vscode
global-exclude .idea
global-exclude *.swp
global-exclude *.swo
global-exclude *~
global-exclude *.so

# Virtual environments
prune venv
prune env
prune .venv

# Simulation output
prune vtk*
